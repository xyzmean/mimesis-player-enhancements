<?xml version="1.0" encoding="utf-8"?>
<Project>
  <!-- Optional local game install (enables CopyToMods). Not required to compile. -->
  <Import Project="$(MSBuildThisFileDirectory)..\PathConfig.props" Condition="Exists('$(MSBuildThisFileDirectory)..\PathConfig.props')" />
  <Import Project="$(MSBuildThisFileDirectory)Directory.Build.user.props" Condition="Exists('$(MSBuildThisFileDirectory)Directory.Build.user.props')" />

  <PropertyGroup>
    <RepoRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\'))</RepoRoot>
    <DepsPath Condition="'$(DepsPath)' == ''">$(RepoRoot)deps</DepsPath>
    <ReferenceRoot>$(DepsPath)/reference</ReferenceRoot>

    <!-- Output: dist/debug (Debug) or dist/prod (Release). Directory.Build.props runs before SDK defaults Configuration. -->
    <Configuration Condition="'$(Configuration)' == ''">Debug</Configuration>
    <DistFolder Condition="'$(Configuration)' == 'Release'">prod</DistFolder>
    <DistFolder Condition="'$(DistFolder)' == ''">debug</DistFolder>
    <BaseOutputPath>$(RepoRoot)dist\$(DistFolder)\</BaseOutputPath>
    <OutputPath>$(BaseOutputPath)</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Default: compile against bootstrapped reference DLLs in deps/reference/ -->
    <GameAssemblyPath Condition="'$(GameAssemblyPath)' == ''">$(ReferenceRoot)/Managed</GameAssemblyPath>
    <MelonLoaderPath Condition="'$(MelonLoaderPath)' == ''">$(ReferenceRoot)/MelonLoader/net35</MelonLoaderPath>
    <!-- Optional local game install: use game Managed DLLs when present; MelonLoader only if installed in game. -->
    <GamePath Condition="'$(GamePath)' == ''">$(MIMESIS_PATH)</GamePath>
    <UseGameManagedReferences Condition="'$(UseGameManagedReferences)' == '' and '$(GamePath)' != '' and Exists('$(GamePath)/MIMESIS_Data/Managed/Assembly-CSharp.dll')">true</UseGameManagedReferences>
    <GameAssemblyPath Condition="'$(UseGameManagedReferences)' == 'true'">$(GamePath)/MIMESIS_Data/Managed</GameAssemblyPath>
    <MelonLoaderPath Condition="'$(GamePath)' != '' and Exists('$(GamePath)/MelonLoader/net35/MelonLoader.dll')">$(GamePath)/MelonLoader/net35</MelonLoaderPath>
    <PluginsPath Condition="'$(PluginsPath)' == '' and '$(GamePath)' != ''">$(GamePath)/Mods</PluginsPath>
  </PropertyGroup>

  <Target Name="ValidateReferenceAssemblies" BeforeTargets="ResolveReferences">
    <Error Condition="!Exists('$(GameAssemblyPath)/Assembly-CSharp.dll')"
           Text="Assembly-CSharp.dll not found at $(GameAssemblyPath). Run: ./scripts/bootstrap-deps.sh" />
    <Error Condition="'$(IsInspectionTool)' != 'true' and !Exists('$(MelonLoaderPath)/MelonLoader.dll')"
           Text="MelonLoader.dll not found at $(MelonLoaderPath). Run: ./scripts/bootstrap-deps.sh" />
  </Target>
</Project>
